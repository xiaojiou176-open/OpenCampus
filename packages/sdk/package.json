{
  "name": "@campus-copilot/sdk",
  "version": "0.1.0",
  "private": false,
  "description": "Read-only SDK for Campus Copilot local BFF and imported workspace snapshots.",
  "license": "MIT",
  "keywords": ["campus-copilot", "sdk", "local-first", "read-only", "snapshot"],
  "homepage": "https://github.com/xiaojiou176-open/campus-copilot/tree/main/packages/sdk",
  "bugs": {
    "url": "https://github.com/xiaojiou176-open/campus-copilot/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xiaojiou176-open/campus-copilot.git",
    "directory": "packages/sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "files": ["README.md", "src", "tsconfig.json"],
  "exports": {
    ".": "./src/index.ts",
